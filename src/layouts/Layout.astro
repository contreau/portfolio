---
const {
  description,
  title,
  ogURL,
  hasFixedHeader,
  pathName,
  indexIsActive,
  portfolioIsActive,
  musingsIsActive,
} = Astro.props;
interface Props {
  description: string;
  title: string;
  ogURL: string;
  hasFixedHeader?: boolean;
  pathName: string;
  indexIsActive?: string;
  portfolioIsActive?: string;
  musingsIsActive?: string;
}

import Path from "@components/chips/Path.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <slot name="headshot-preload" />
    <slot name="image-preload" />
    <meta property="og:type" content="website" />
    <title>Conor Kelley | {title}</title>
    <meta name="title" content={`Conor Kelley | ${title}`} />
    <meta property="og:title" content={`Conor Kelley | ${title}`} />
    <meta name="description" content={description} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogURL} />
    <script is:inline>
      (function () {
        const theme = sessionStorage.getItem("theme");
        if (theme === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (theme === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.setAttribute("data-theme", prefersDark ? "dark" : "light");
        }
      })();

      // Animated header
      const header = document.querySelector("header");
      const stored_classes = sessionStorage.getItem("animatedHeader");
      if (stored_classes === null) {
        sessionStorage.setItem("animatedHeader", "true");
      } else if (stored_classes === "true") {
        header.classList.remove("animated-header");
      }
    </script>
  </head>
  <body>
    <Header fixed={hasFixedHeader} />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --text: #000000;
    --white: #ffffff;
    --light-background: #ffffff;
    --primary: #2059cb;
    --primary-link: #2059cb;
    --light-text: #090909;
    --gw-blue: #033c5a;
    --bu-red: #cd0001;
    --apps-green: #01a366;
    --social-links-color: #74757b;
    --headshot-shadow: #74757b40;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 112.5%; /*18px*/
    scroll-behavior: smooth;
    scrollbar-gutter: stable;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  img {
    max-width: 100%;
    display: block;
    height: auto;
  }

  body {
    font-family: system-ui;
    font-weight: 400;
    line-height: 1.75;
    /* background-color: var(--dark-background);
    color: #090909;
    --text: #090909; */
    max-width: 1200px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  html[data-theme="light"] body {
    color: #000000;
    background-color: #ffffff;
    --text: #090909;
    --bg-color: #ffffff;
    --primary: #2059cb;
    --primary-link: #2059cb;
    --social-links-color: #74757b;
    --headshot-shadow: #74757b40;
    --table-head-color: #ececec;
    --table-bg: #fafafa;
  }

  html[data-theme="dark"] body {
    color: #ffffff;
    background-color: #111827;
    --bg-color: #111827;
    --social-links-color: #ffffff;
    --primary: #728bd2;
    --primary-link: #88a6fa;
    --text: #ffffff;
    --headshot-shadow: #475681;
    --table-head-color: #1d2641;
    --table-bg: #323e61;
  }

  @media (prefers-color-scheme: dark) {
    body {
      color: #ffffff;
      background-color: #111827;
      --bg-color: #111827;
      --social-links-color: #ffffff;
      --primary: #728bd2;
      --primary-link: #88a6fa;
      --text: #ffffff;
      --headshot-shadow: #475681;
    }
  }

  /* Font Configurations for headings / paragraphs */

  p {
    font-size: clamp(0.85rem, 4vw, 1.05rem);
  }

  h1,
  h2,
  h3 {
    font-family: system-ui;
    line-height: 1.3;
  }

  h2 {
    font-size: clamp(1.2rem, 6vw, 1.75rem);
    font-weight: 550;
    color: var(--primary);
    margin-block: 0;
  }

  h2 span {
    color: var(--text);
    font-weight: 500;
    &.gt {
      margin-right: 0.5rem;
    }
  }

  h3 {
    font-size: clamp(1rem, 6vw, 1.4rem);
    color: var(--text);
    font-weight: 450;
  }

  /* Nav / Footer */

  nav {
    padding-left: 0.2em;
  }

  nav.mobile-nav {
    display: none;
  }

  nav ul {
    display: flex;
    gap: 3rem;
    padding-left: 0;

    li {
      list-style-type: none;
      position: relative;
      font-size: clamp(1rem, 6vw, 1.25rem);
    }

    li.active {
      color: var(--primary);
    }

    li.active::after {
      content: "";
      position: absolute;
      width: 6.5px;
      height: 6.5px;
      background-color: var(--primary);
      border-radius: 50%;
      bottom: -28%;
      transform: translate(-50%, -50%);
      left: 50%;
    }

    li.active a {
      color: var(--primary-link);
    }

    a {
      text-decoration: none;
      color: var(--text);
      font-weight: 550;
      transition: color 200ms;
    }

    a:hover {
      color: var(--primary-link);
    }
  }

  section {
    /* margin-block: 2.5rem; */
    min-height: 340px;
  }

  /* Other global rules */
  p.description {
    margin-block: 1.5rem;
    font-weight: 350;
  }

  p.subpage-description a {
    color: var(--primary);
  }

  /* @ rules */

  @keyframes fadeIn {
    100% {
      opacity: 1;
    }
  }

  @keyframes shiftUp {
    0% {
      transform: translateY(10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @keyframes shiftDown {
    0% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @media (max-width: 1100px) {
    nav {
      display: none;
    }
    nav.mobile-nav {
      display: block;
    }

    nav.mobile-nav ul {
      justify-content: center;
      li {
        font-size: clamp(0.85rem, 4vw, 1rem);
      }

      li.active::after {
        width: 5px;
        height: 5px;
      }
    }

    nav ul {
      gap: 1.5rem;
    }

    section {
      margin-block: 1rem;
    }

    section h2,
    section p.description {
      text-align: center;
    }

    p.subpage-description {
      text-align: center;
    }
  }

  @media (max-width: 1200px) {
    body {
      padding-inline: 1em;
    }
  }
</style>
