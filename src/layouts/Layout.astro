---
const { description, title, ogURL, activePage } = Astro.props;
interface Props {
  description: string;
  title: string;
  ogURL: string;
  activePage: string;
}

import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Nav from "@components/Nav.astro";
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <slot name="headshot-preload" />
    <slot name="image-preload" />
    <meta property="og:type" content="website" />
    <title>Conor Kelley | {title}</title>
    <meta name="title" content={`Conor Kelley | ${title}`} />
    <meta property="og:title" content={`Conor Kelley | ${title}`} />
    <meta name="description" content={description} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogURL} />
  </head>
  <body>
    <Header />
    <main>
      <Nav activePage={activePage} />
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main {
    display: grid;
    grid-template-columns: 10% 85%;
    gap: 5%;
    align-items: start;
    flex-grow: 1;
    margin-top: 2rem;
    position: relative;
  }

  @media (max-width: 1200px) {
    main {
      display: block;
      margin-top: 0;
    }
  }

  :root {
    --text: #000000;
    --white: #ffffff;
    --light-background: #ffffff;
    --primary: #2059cb;
    --primary-link: #2059cb;
    --light-text: #090909;
    --gw-blue: #033c5a;
    --bu-red: #cd0001;
    --apps-green: #01a366;
    --social-links-color: #74757b;
    --headshot-shadow: #74757b40;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 112.5%; /*18px*/
    scroll-behavior: smooth;
    scrollbar-gutter: stable;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
  }

  img {
    max-width: 100%;
    display: block;
    height: auto;
  }

  body {
    position: relative;
    font-family: system-ui;
    font-weight: 400;
    line-height: 1.75;
    max-width: 1200px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    min-height: 100dvh;
  }

  html[data-theme="light"] body {
    color: #000000;
    background-color: #ececec;
    --text: #090909;
    --bg-color: #ececec;
    --primary: #2059cb;
    --primary-link: #2059cb;
    --social-links-color: #74757b;
    --headshot-shadow: #74757b40;
    --table-head-color: #ececec;
    --table-bg: #fafafa;
  }

  html[data-theme="dark"] body {
    color: #ffffff;
    background-color: #111827;
    --bg-color: #111827;
    --social-links-color: #d4d4d4;
    --primary: #728bd2;
    --primary-link: #88a6fa;
    --text: #d4d4d4;
    --headshot-shadow: #475681;
    --table-head-color: #1d2641;
    --table-bg: #323e61;
  }

  @media (prefers-color-scheme: dark) {
    body {
      color: #ffffff;
      background-color: #111827;
      --bg-color: #111827;
      --social-links-color: #ffffff;
      --primary: #728bd2;
      --primary-link: #88a6fa;
      --text: #ffffff;
      --headshot-shadow: #475681;
    }
  }

  /* Font Configurations for headings / paragraphs */

  p,
  li {
    font-size: clamp(0.85rem, 4vw, 0.9rem);
  }

  h1,
  h2,
  h3 {
    font-family: system-ui;
    line-height: 1.3;
  }

  h2 {
    font-size: clamp(1.2rem, 6vw, 1.75rem);
    font-weight: 250;
    color: var(--text);
    margin-block: 0;
  }

  h2 span {
    color: var(--text);
    font-weight: 500;
  }

  h2 span.gt {
    margin-right: 0.5rem;
  }

  h3 {
    /* font-size: clamp(1rem, 8vw, 1.4rem); */
    font-size: 1.4rem;
    color: var(--text);
    font-weight: 150;
  }

  section {
    /* margin-block: 2.5rem; */
    min-height: 340px;
  }

  /* Other global rules */
  p,
  li {
    color: var(--text);
    font-weight: 200;
    font-size: clamp(0.85rem, 4vw, 1rem);
  }

  p.description {
    margin-block: 1.5rem;
    font-weight: 200;
  }

  p.subpage-description a,
  p > a {
    color: var(--primary);
  }

  li::marker {
    color: var(--primary);
  }

  div.social-links ul {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-left: 0;
    margin-block: 0;
    height: 100%;
    line-height: 1;

    li {
      list-style-type: none;
      padding: 0em 0.6em;
      border-radius: 5px;
      padding-inline: 0;
      a {
        text-decoration: none;
        color: var(--social-links-color);
        transition: color 200ms;
      }

      a:hover {
        color: var(--primary-link);
      }
    }
  }

  /* @ rules */

  @keyframes fadeIn {
    100% {
      opacity: 1;
    }
  }

  @keyframes shiftUp {
    0% {
      transform: translateY(10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @keyframes shiftDown {
    0% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @media (max-width: 1100px) {
    section {
      margin-block: 1rem;
    }

    section h2,
    section p.description {
      text-align: center;
    }

    p.subpage-description {
      text-align: center;
      text-wrap: balance;
    }
  }

  @media (max-width: 1200px) {
    body {
      padding-inline: 1em;
    }
  }
</style>
