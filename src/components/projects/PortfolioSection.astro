---
const { heading, timeline, marginTop } = Astro.props;
interface Props {
  heading: string;
  timeline?: string;
  marginTop?: string;
}
---

<section class:list={[{ "margin-top": marginTop === "true" }]}>
  <div class="heading-timeline">
    <h2>{heading}</h2>
    <span class="timeline">{timeline}</span>
  </div>
  <slot name="description" />
  <slot />
</section>

<style>
  section.margin-top {
    margin-top: 3rem;
  }

  .heading-timeline {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  .timeline {
    background-color: var(--bg-color);
    border: solid 1.5px #728bd24f;
    margin-top: 0.5rem;
    display: inline-block;
    align-self: flex-start;
    font-size: 0.8rem;
    font-weight: 550;
    padding: 0.1em 1em;
    color: #ffffff;
    border-radius: 30px;
  }

  .timeline:empty {
    display: none;
  }

  p.description {
    margin-block: 1.5rem;
    max-width: 80%;
  }

  @media (max-width: 1100px) {
    .heading-timeline {
      flex-direction: column;
      text-align: center;
      align-items: center;
      gap: 1rem;
    }

    .timeline {
      align-self: center;
    }

    h2 {
      text-wrap: balance;
    }

    p.description {
      max-width: 100%;
      text-align: center;
    }
  }
</style>
