<pre id="ascii-canvas"></pre>

<script>
  const asciiCanvas = document.getElementById("ascii-canvas");

  function animateAscii(asciiType: string) {
    asciiCanvas.textContent = "";
    const lines = asciiType.split("\n");
    let i = 0;
    const interval = setInterval(() => {
      if (i < lines.length) {
        asciiCanvas.textContent += `${lines[i]}\n`;
        i++;
      } else {
        clearInterval(interval);
      }
    }, 17);
  }

  const asciiDark = `
                                          ..--                                                     
                                      -......------                                                 
                                -  --....-...........--                                             
                               ----.....-............---..--                                        
                            -----....................---......--                                    
                           ....................................----                                 
                          -......................---..............-                                 
                     - --..............................---...........-                              
                    ---...............--...-..............-..........-.                             
                     -...........-----------...........---.............-                            
                    ..........----------------------...................-                            
                    ........------------++++++---+++++----..............                            
                    .......-----------++++++++++++++++++++--+-..........-                           
                    -......---------+++++++++++++++++++++++++----+-......                           
                    -......-------++++++++++++++++++++++++++++++++-......                           
                    -......--------++++++++++++++++++++++++++++++++.....-                           
                     .....------------+++++++++++---+---------+++++.....                            
                      -....---..........----------...-------+++++++....-                            
                       -...-..-----......---+++-----.--+++---++++++....                             
                        ...-----------...---+++++----....-.--++++++...++                            
                         ..-----.-....-..--++++++++++----++++++++++-.---+                           
                         ..--------+-+-----+++++++++++-++++++++++++-++--+                           
                         ..--------++++----+++++++++++++++++++++++++-+++-                           
                         ..-----+++++++----+++++++++++++++++++++++++++++                            
                         -.------+++++--.--++++++++++++++++++++++++-+++                             
                          .-------+++--------+++++++---++++++++++++-+++                             
                          -.--.--------.......--..-+++--+++++++++++-++                              
                          -.--.--------.......--+++++++++++++++++++-                                
                           -.-----------....-------++----++++++++++-                                
                            ..---------....--++++++++--.--+++++++++-                                
                            -..-----.--.........-++++++--+++++++++--                                
                             ....--------------++++++++++++++++++--                                 
                             ......---------------+++++++++++++----                                 
                              -......---------++++++++++++++------                                  
                               ......-----++++++++++++++++++--.++                                   
                                 ......-------++++++++++----..+++                                   
                                   ........----------------.-+++++                                  
                                   ..................-.-..--++++++                                  
                                   .....................--++++++++                                  
                                   -.................---++++++++++                                  
                                   -..............---++++++++++++++                                 
                                   -............----++++++++++++++++                                
                                   .............----+++++++++++++++++                               
                               .........----.....---++++++++++++++++++...                           
                             ...........------------+++++++++++++++++.......-                       
                          ..............------------++++++++++++++++............                    
                      ...........-......------------++++++++++++++-................-                
                 ......................-----+++-----++++++++++++.......................             
             .........................-----++++++++++++++++-................................        
         .....................................----..............................................    
     .............................................................................................  
  ................................................................................................. 
....................................................................................................
`;

  animateAscii(asciiDark);
</script>

<style>
  pre#ascii-canvas {
    line-height: 1;
    font-size: 4.25px;
    height: 230px;
    width: 260px;
  }

  @media (max-width: 1100px) {
    pre#ascii-canvas {
      order: -1;
      margin-inline: auto;
    }
  }
</style>
