---
const { activePage } = Astro.props;
interface Props {
  activePage: string;
}
---

<nav>
  <ul>
    <li class:list={[{ active: activePage === "about" }]}><a href="/">About</a></li>
    <li class:list={[{ active: activePage === "work" }]}><a href="/work">Work</a></li>
    <li class:list={[{ active: activePage === "projects" }]}><a href="/projects">Projects</a></li>
  </ul>
</nav>

<style>
  ul {
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-block: 0;
  }

  li {
    list-style-type: none;
    position: relative;
    font-size: 1rem;
    font-weight: 300;
  }

  li.active a {
    color: var(--primary);
  }

  li.active::after {
    content: "";
    position: absolute;
    width: 6.5px;
    height: 6.5px;
    background-color: var(--primary);
    border-radius: 50%;
    left: -10px;
    transform: translate(-50%, -50%);
  }

  li a {
    text-decoration: none;
    color: var(--text);
    transition: color 200ms;
  }

  @media (min-width: 1200px) {
    nav {
      position: sticky;
      top: 1rem;
    }

    li.active::after {
      top: 50%;
    }
  }

  @media (max-width: 1200px) {
    nav {
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeIn 500ms ease-in forwards;
    }

    ul {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
    }

    li.active::after {
      left: 50%;
      bottom: -50%;
    }
  }
</style>
