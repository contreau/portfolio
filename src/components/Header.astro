<style>
  /* .header-wrapper {
    position: absolute;
    top: 0;
  } */

  header {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    padding-top: 1.5em;
    padding-bottom: 1.5em;
    /* position: fixed;
    max-width: 1200px;
    width: 100%;
    top: 0rem;
    z-index: 5;
    background-color: var(--bg-color); */
  }

  header.fixed {
