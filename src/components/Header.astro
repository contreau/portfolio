---
import GithubSVG from "../svg/GithubSVG.astro";
import LinkedinSVG from "../svg/LinkedinSVG.astro";
import EmailSVG from "../svg/EmailSVG.astro";
import ResumeSVG from "../svg/ResumeSVG.astro";
import DarkThemeSVG from "../svg/DarkThemeSVG.astro";
import LightThemeSVG from "../svg/LightThemeSVG.astro";
import SystemThemeSVG from "../svg/SystemThemeSVG.astro";
---

<script>
  let theme = "system";
  const lightmodeToggle = document.querySelector("#light-mode-toggle");

  // Configure light/dark mode
  // TODO: swap out SVGs on click (can't use the Astro component aliases)
  document.addEventListener("DOMContentLoaded", () => {
    function applySystemTheme() {
      const prefersDarkScheme = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (prefersDarkScheme) {
        document.body.setAttribute("data-theme", "dark");
      } else {
        document.body.setAttribute("data-theme", "light");
      }
    }

    if (theme === "system") {
      applySystemTheme();
    }

    lightmodeToggle.addEventListener("click", () => {
      console.log(theme);
      if (theme === "system") {
        theme = "dark";
        document.body.setAttribute("data-theme", "dark");
      } else if (theme === "dark") {
        theme = "light";
        document.body.setAttribute("data-theme", "light");
      } else {
        theme = "system";
        applySystemTheme();
      }
    });
  });
</script>

<header>
  <h1 class="title-name">
    <a href="/"
      ><span style="color: var(--primary)">Conor</span><span style="color: var(--text);"
        >Kelley</span
      ></a
    >
  </h1>

  <div class="social-links">
    <ul>
      <li>
        <button id="light-mode-toggle"><SystemThemeSVG /></button>
      </li>
      <li>
        <a href="https://github.com/contreau" target="_blank" aria-label="Github Profile"
          ><GithubSVG /></a
        >
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/conor-kelley2/"
          target="_blank"
          aria-label="Linkedin Profile"><LinkedinSVG /></a
        >
      </li>
      <li class="cv">
        <a href="/cv.pdf" target="_blank" aria-label="Curriculum Vitae / Resume"><ResumeSVG /></a>
      </li>
      <li>
        <a href="mailto:cfk102@gmail.com" target="_blank" aria-label="Email"><EmailSVG /></a>
      </li>
    </ul>
  </div>
</header>

