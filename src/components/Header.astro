---
import GithubSVG from "@svg/GithubSVG.astro";
import LinkedinSVG from "@svg/LinkedinSVG.astro";
import EmailSVG from "@svg/EmailSVG.astro";
import ResumeSVG from "@svg/ResumeSVG.astro";

interface Props {
  fixed: boolean;
}
const { fixed } = Astro.props;
---

<script>
  // Configure light/dark mode

  // TODO: make theme icon responsive / put a pipe or separator between theme toggle and icons?

  document.addEventListener("DOMContentLoaded", () => {
    const themeToggle = document.getElementById("theme-toggle")!;

    const icons = {
      dark: "/svg/DarkTheme.svg",
      light: "/svg/LightTheme.svg",
      system: "/svg/SystemTheme.svg",
    };

    function setThemeInSessionStorage(targetTheme: string) {
      sessionStorage.setItem("theme", targetTheme);
    }

    function applySystemTheme() {
      const prefersDarkScheme = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.setAttribute("data-theme", prefersDarkScheme ? "dark" : "light");
      setThemeInSessionStorage("system");
    }

    const currentTheme = sessionStorage.getItem("theme");
    if (currentTheme === null || currentTheme === "system") {
      applySystemTheme();
      themeToggle.innerHTML = `<img src="${icons.system}" alt="System Theme" title="System Theme" />`;
    } else if (currentTheme === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
      themeToggle.innerHTML = `<img src="${icons.dark}" alt="Dark Theme" title="Dark Theme" />`;
    } else if (currentTheme === "light") {
      document.documentElement.setAttribute("data-theme", "light");
      themeToggle.innerHTML = `<img src="${icons.light}" alt="Light Theme" title="Light Theme" />`;
    }

    themeToggle.addEventListener("click", () => {
      let currentTheme = sessionStorage.getItem("theme");
      if (currentTheme === "system") {
        setThemeInSessionStorage("dark");
        document.documentElement.setAttribute("data-theme", "dark");
        themeToggle.innerHTML = `<img src="${icons.dark}" alt="Dark Theme" title="Dark Theme" />`;
      } else if (currentTheme === "dark") {
        setThemeInSessionStorage("light");
        document.documentElement.setAttribute("data-theme", "light");
        themeToggle.innerHTML = `<img src="${icons.light}" alt="Light Theme" title="Light Theme" />`;
      } else {
        setThemeInSessionStorage("system");
        applySystemTheme();
        themeToggle.innerHTML = `<img src="${icons.system}" alt="System Theme" title="System Theme" />`;
      }
    });
  });
</script>

<header class:list={["", { fixed: fixed }]}>
  <h1 class="title-name">
    <a href="/"
      ><span style="color: var(--primary)">Conor</span><span style="color: var(--text);"
        >Kelley</span
      ></a
    >
  </h1>

  <div class="social-links">
    <ul>
      <li>
        <button id="theme-toggle" aria-label="Light/Dark Theme Toggle"></button>
      </li>
      <li>
        <a href="https://github.com/contreau" target="_blank" aria-label="Github Profile"
          ><GithubSVG /></a
        >
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/conor-kelley2/"
          target="_blank"
          aria-label="Linkedin Profile"><LinkedinSVG /></a
        >
      </li>
      <li class="cv">
        <a href="/cv.pdf" target="_blank" aria-label="Curriculum Vitae / Resume"><ResumeSVG /></a>
      </li>
      <li>
        <a href="mailto:cfk102@gmail.com" target="_blank" aria-label="Email"><EmailSVG /></a>
      </li>
    </ul>
  </div>
</header>

