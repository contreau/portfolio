<style>
  /* .header-wrapper {
    position: absolute;
    top: 0;
  } */

  header {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    padding-top: 1.5em;
    padding-bottom: 1.5em;
    position: fixed;
    max-width: 1200px;
    width: 100%;
    top: 0rem;
    z-index: 5;
    background-color: var(--bg-color);
  }

  h1 {
    font-size: clamp(2.5rem, 9vw, 3rem);
    /* font-size: 3.5rem; */
    line-height: 1;
    font-weight: 500;
    margin-bottom: 0;
    margin-top: 0;

    a {
      text-decoration: none;
    }
  }

  div.social-links ul {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-left: 0;
    margin-block: 0;
    height: 100%;
    line-height: 1;

    li {
      list-style-type: none;
      padding: 0em 0.6em;
      border-radius: 5px;
      padding-inline: 0;
      a {
        text-decoration: none;
        color: var(--social-links-color);
        transition: color 200ms;
      }

      a:hover {
        color: var(--primary-link);
      }
    }
  }

  button {
    background-color: transparent;
    border: none;
    cursor: pointer;
  }

  /* @ rules */
  @media (max-width: 1100px) {
    header {
      position: relative;
      margin-inline: auto;
      text-align: center;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
  }
</style>
